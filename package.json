{
  "name": "blacksof-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "web": "yarn workspace web",
    "server": "yarn workspace server",
    "dev": "npx concurrently \"yarn web dev\" \"yarn server dev\"",
    "build": "yarn build:web && yarn build:server",
    "build:web": "yarn workspace web build",
    "build:server": "yarn workspace server build",
    "start:server": "yarn workspace server start",
    "start:web": "yarn workspace web start",
    "start": "yarn build && npx concurrently \"yarn start:web\" \"yarn start:server\""
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^4.17.17",
    "@types/node": "25.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "concurrently": "^9.2.1",
    "next": "15.1.0",
    "next-themes": "^0.3.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "tailwindcss": "^4",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.3"
  },
  "resolutions": {
    "typescript": "5.9.3",
    "@types/node": "25.8.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@radix-ui/react-slot": "1.2.3"
  }
  
}
