{
  "name": "blacksof-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "web": "yarn workspace @blacksof/web",
    "server": "yarn workspace @blacksof/server",
    "dev": "npx concurrently \"yarn web dev\" \"yarn server dev\"",
    "build": "yarn build:web && yarn build:server",
    "build:web": "yarn install --production=false && yarn workspace @blacksof/web build",
    "build:server": "yarn install --production=false && yarn workspace @blacksof/server build",
    "start:server": "yarn workspace @blacksof/server start",
    "start:web": "yarn workspace @blacksof/web start",
    "start": "yarn build && npx concurrently \"yarn start:web\" \"yarn start:server\""
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^4.17.17",
    "@types/node": "22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "next": "15.1.7",
    "next-themes": "^0.3.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "tailwindcss": "^4",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.3"
  },
  "resolutions": {
    "typescript": "5.9.3",
    "@types/node": "22.10.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@radix-ui/react-slot": "1.2.3"
  }
  
}
