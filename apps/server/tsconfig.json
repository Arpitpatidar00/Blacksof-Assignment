{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "types": ["node", "express", "multer", "cors", "morgan", "compression"],
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "paths": {
      "@blacksof/types": ["../../libs/types/src"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "../../libs/types/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
